---
permalink: /talks.json
eleventyExcludeFromCollections: true
---
[
  {% for talk in collections.talksApi %}
    {% assign t = talk.data %}
    {
        "talk": {{t.talk}},
        "speakers": {{t.speakers}},
        "url": "{{site.baseURL}}{{talk.url}}",
        "video": "https://stream.mux.com/{{t.video}}.m3u8",
        "slug": "{{talk.fileSlug}}",
        "tags": {{t.tags}},
        "transcript": "{{talk.templateContent}}"
    },
  {% endfor  %}
]
