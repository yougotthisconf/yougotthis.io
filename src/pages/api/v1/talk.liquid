---
pagination:
    data: collections.talks
    size: 1
    alias: talk
permalink: "/talks/{{ talk.fileSlug }}.json"
---
{% assign t = talk.data %}
{
    "talk": {{t.talk}},
    "speakers": [
        {% for speaker in t.speakers %}
        {
            "name": "{{speaker.name}}",
            "bio": "{{speaker.bio}}",
            {% if speaker.twitter %}
                "twitter": "{{speaker.twitter}}",
            {% endif %}
            "photo": "{{site.baseURL}}/assets/img/people/{{speaker.photo}}"
        }
        {% unless forloop.last %},{% endunless %}
        {% endfor %}
    ],
    "url": "{{site.baseURL}}{{talk.url}}",
    "video": "https://stream.mux.com/{{t.video}}.m3u8",
    "slug": "{{talk.fileSlug}}",
    "transcript": "{{talk.templateContent}}",
}
