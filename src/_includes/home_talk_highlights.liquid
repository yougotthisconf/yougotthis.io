<div class='mt-12 lg:mt-24'>
  <h2 class="tw-heading-2">Some of our favorite talks</h2>
  <div class="grid grid-cols-1 gap-4 max-w-screen-xl mx-auto p-4 lg:mt-5 sm:grid-cols-2 lg:grid-cols-3">
    {% for talk in collections.talks %}
      {% if talk.data.highlight %}
        {% include talk_card, talk: talk %}
      {% endif %}
    {% endfor %}
  </div>
  <span class="flex justify-center rounded-md p-4">
    <a href="/talks" class="tw-btn">Full Talk Library</a>
  </span>
</div>
